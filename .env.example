# ═══════════════════════════════════════════════════════════════════════════════
# HuggingFace Tokens — copy this file to .env and fill in your tokens
# ═══════════════════════════════════════════════════════════════════════════════
# Create tokens at: https://huggingface.co/settings/tokens
#
# HF_TOKEN_READ   — Read permission, for downloading dataset & weights
# HF_TOKEN_WRITE  — Write permission, for pushing training results to HF
# ═══════════════════════════════════════════════════════════════════════════════

HF_TOKEN_READ=
HF_TOKEN_WRITE=

# ═══════════════════════════════════════════════════════════════════════════════
# WandB API Key
# ═══════════════════════════════════════════════════════════════════════════════
# Get your key at: https://wandb.ai/authorize
WANDB_API_KEY=

# CUDA library path (uncomment if you get "CUDA driver initialization failed")
# LD_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu:/usr/local/cuda/lib64
